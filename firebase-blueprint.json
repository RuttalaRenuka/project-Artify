{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account containing visual setup and address records.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "addresses": { "type": "array" },
        "paymentMethods": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order History",
      "description": "Visual craft supplies orders made on artify.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "shipping": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "items", "total"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of creative user accounts."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Universal historical order lists."
    }
  }
}
